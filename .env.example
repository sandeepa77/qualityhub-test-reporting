# QualityHub Environment Variables — copy to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development
DEFAULT_ORG_ID=my-org

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=test-events
KAFKA_GROUP_ID=analytics-engine

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=qualityhub
POSTGRES_PASSWORD=qualityhub_secret
POSTGRES_DB=qualityhub

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
